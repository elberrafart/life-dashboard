# ── Supabase ───────────────────────────────────────────────────────────────
# Project URL (e.g. https://your-project.supabase.co). Required.
SUPABASE_URL=

# Anon (public) key — used for user-facing auth flows. Subject to RLS.
# Required.
SUPABASE_ANON_KEY=

# Service role key — bypasses RLS. NEVER prefix with NEXT_PUBLIC_ and never
# import the admin client from a client component. Required.
SUPABASE_KEY=

# ── App ────────────────────────────────────────────────────────────────────
# Email of the bootstrap super-admin. This email gains admin access without
# needing a row in the app_admins table. Optional in dev — leave blank and
# grant admin access manually via the database.
ADMIN_EMAIL=

# Public site URL used for password-reset and OAuth redirect callbacks.
# Defaults to http://localhost:3000 in development. Set this to your
# deployed origin in production (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=
